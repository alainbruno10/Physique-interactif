        .btn-lecon{padding:12px;border-radius:10px;border:2px solid #e9ecef;background:#f8f9fa;cursor:pointer;text-align:center}
        .btn-lecon .lecon-num{display:inline-block;background:#1a2a6c;color:white;border-radius:50%;width:24px;height:24px;line-height:24px;font-size:0.7rem;font-weight:700;margin-bottom:3px}
