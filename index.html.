        <div id="question-actions" class="mt-20"></div>
    </div>
    <div id="page-resultats" class="hidden">
        <h2 style="text-align:center;color:#1a2a6c;font-size:1rem;">📊 Résultats</h2>
        <p style="text-align:center;font-size:0.8rem;color:#555;" id="result-titre"></p>
        <div class="score-circle" id="score-display">0 <small>/5</small></div>
        <div class="result-detail">
            <p><span id="result-nom"></span>, votre score :</p>
            <p>✅ <span id="result-juste" style="color:#28a745;">0</span> | ❌ <span id="result-faux" style="color:#dc3545;">0</span></p>
        </div>
        <button class="btn btn-whatsapp" onclick="envoyer()">📱 Envoyer</button>
        <button class="btn btn-primary mt-10" onclick="retour()">📚 Retour</button>
    </div>
</div>
<script>
const NUMERO_WHATSAPP="237694723256";
const modulesData={
"1D_mesures":{titre:"Mesures et Incertitudes",niveau:"1ere",serie:"D",icone:"📏",lecons:[
{titre:"Incertitude",questions:[
{q:"Qu'est-ce que l'incertitude ?",o:["Erreur","Intervalle contenant la valeur vraie","Différence","Précision"],r:1,e:"L'incertitude est l'intervalle contenant la valeur vraie."},
{q:"Erreur systématique :",o:["Variable","Toujours du même signe","Due à la résolution","Négligeable"],r:1,e:"L'erreur systématique est constante."},
{q:"Erreur aléatoire due à :",o:["Défaut","Fluctuations","Mauvaise utilisation","Erreur calcul"],r:1,e:"Due à des fluctuations."},
{q:"Valeur vraie :",o:["Mesurée","Théorique","Moyenne","Affichée"],r:1,e:"Valeur théorique inconnue."},
{q:"12,5 ± 0,2 cm : 0,2 est :",o:["Erreur lecture","Incertitude élargie","Écart-type","Résolution"],r:1,e:"0,2 est l'incertitude élargie."}
]},
{titre:"Qualités d'un instrument",questions:[
{q:"La fidélité est :",o:["Proche vraie","Reproductible","Détecter variations","Stable"],r:1,e:"Fidélité = reproductibilité."},
{q:"La sensibilité est :",o:["Plus petite variation","Écart","Stabilité","Rapidité"],r:0,e:"Sensibilité = plus petite variation."},
{q:"La justesse est :",o:["Reproductible","Proche vraie","Détecter variations","Stable"],r:1,e:"Justesse = proche de la vraie."},
{q:"La résolution est :",o:["Plus petite variation","Plus grande valeur","Rapidité","Stabilité"],r:0,e:"Résolution = plus petite variation."},
{q:"La portée est :",o:["Petite valeur","Grande valeur","Étendue","Précision"],r:2,e:"Portée = étendue des valeurs."}
]}
]},
"1D_mecanique":{titre:"Mécanique",niveau:"1ere",serie:"D",icone:"⚙️",lecons:[
{titre:"Travail d'une force",questions:[
{q:"Travail d'une force constante :",o:["W=F×AB","W=F·AB","W=F×AB","W=F/AB"],r:1,e:"W = F·AB."},
{q:"Travail du poids en descente :",o:["Nul","Positif","Négatif","Variable"],r:1,e:"Le poids est dans le sens → positif."},
{q:"Travail du poids en montée :",o:["Nul","Positif","Négatif","Variable"],r:2,e:"Le poids s'oppose → négatif."},
{q:"Force conservative :",o:["Dépend chemin","Dépend positions","Toujours nulle","Toujours positive"],r:1,e:"Indépendant du chemin."},
{q:"Travail d'un couple M :",o:["W=M×θ","W=M/θ","W=θ/M","W=M×θ²"],r:0,e:"W = M×θ."}
]},
{titre:"Puissance",questions:[
{q:"Puissance moyenne :",o:["P=W×Δt","P=W/Δt","P=Δt/W","P=F×v"],r:1,e:"P = W/Δt."},
{q:"W=600J en 30s : P=?",o:["20W","30W","180W","18000W"],r:0,e:"600/30 = 20W."},
{q:"Unité de puissance :",o:["Joule","Watt","Newton","Pascal"],r:1,e:"L'unité est le Watt."},
{q:"Puissance instantanée :",o:["P=F×v","P=F/v","P=m×a","P=E/t"],r:0,e:"P = F×v."},
{q:"Puissance d'un couple M :",o:["P=M×ω","P=M/ω","P=M×θ","P=M×ω²"],r:0,e:"P = M×ω."}
]}
]},
"1D_optique":{titre:"Optique",niveau:"1ere",serie:"D",icone:"🔦",lecons:[
{titre:"Lentilles - définitions",questions:[
{q:"Lentille convergente : vergence ?",o:["Positive","Négative","Nulle","Variable"],r:0,e:"Vergence positive."},
{q:"Lentille divergente : vergence ?",o:["Positive","Négative","Nulle","Variable"],r:1,e:"Vergence négative."},
{q:"Vergence C = ?",o:["C=f'","C=1/f'","C=-1/f'","C=f'²"],r:1,e:"C = 1/f'."},
{q:"f'=0,25m → C=?",o:["0,25δ","4δ","-4δ","25δ"],r:1,e:"1/0,25 = 4δ."},
{q:"Conditions de Gauss :",o:["Rayons parallèles","Rayons peu inclinés","Lentille convergente","Lentille divergente"],r:1,e:"Rayons paraxiaux."}
]},
{titre:"Construction d'images",questions:[
{q:"Objet à 2f → image :",o:["Infini","2f' autre côté","Foyer F'","Entre F' et 2f'"],r:1,e:"Image à 2f'."},
{q:"Objet entre F et O → image :",o:["Réelle renversée","Virtuelle droite","Réelle droite","Virtuelle renversée"],r:1,e:"Virtuelle, droite, agrandie."},
{q:"Objet au foyer F → image :",o:["Infini","2f'","Foyer F'","Virtuelle"],r:0,e:"Image à l'infini."},
{q:"Objet à l'infini → image :",o:["Infini","Foyer F'","2f'","Virtuelle"],r:1,e:"Image au foyer F'."},
{q:"Lentille divergente → image :",o:["Réelle renversée","Virtuelle droite","Réelle droite","Virtuelle renversée"],r:1,e:"Virtuelle, droite, plus petite."}
]}
]},
"1D_electricite":{titre:"Électricité",niveau:"1ere",serie:"D",icone:"⚡",lecons:[
{titre:"Générateurs et récepteurs",questions:[
{q:"U=E-rI est la tension d'un :",o:["Générateur","Récepteur","Résistor","Condensateur"],r:0,e:"C'est un générateur."},
{q:"La f.é.m. E est :",o:["Tension à vide","Tension en charge","Court-circuit","Puissance"],r:0,e:"E est la tension à vide."},
{q:"U=E'+r'I est la tension d'un :",o:["Générateur","Récepteur","Résistor","Condensateur"],r:1,e:"C'est un récepteur."},
{q:"Un moteur est un :",o:["Générateur","Récepteur","Résistor","Condensateur"],r:1,e:"Un moteur est un récepteur."},
{q:"Ordonnée à l'origine d'un générateur :",o:["r","E","I","P"],r:1,e:"L'ordonnée est E."}
]},
{titre:"Point de fonctionnement",questions:[
{q:"Point de fonctionnement :",o:["Intersection","Valeur résistance","Tension à vide","Puissance max"],r:0,e:"Intersection des caractéristiques."},
{q:"Loi de Pouillet :",o:["I=(E-E')/(r+r')","I=(E+E')/(r+r')","I=(E-E')×(r+r')","I=(E'-E)/(r+r')"],r:0,e:"I = (E-E')/(r+r')"},
{q:"2 générateurs en série : E_eq = ?",o:["E","2E","E/2","0"],r:1,e:"E_eq = 2E."},
{q:"2 générateurs en parallèle : E_eq = ?",o:["E","2E","E/2","0"],r:0,e:"E_eq = E."},
{q:"Résistances en série : R_eq = ?",o:["R₁+R₂","1/R₁+1/R₂","R₁R₂/(R₁+R₂)","R₁R₂"],r:0,e:"R_eq = R₁+R₂."}
]}
]}
]};

let etat={eleve:{nom:"",niveau:"1ere",serie:"D"},moduleActuel:null,leconActuelle:null,questionActuelle:0,reponses:[],score:0,total:0,filtreSerie:"D",leconsCompleted:{}};

function sauvegarder(){try{localStorage.setItem('physique_progression',JSON.stringify({eleve:etat.eleve,leconsCompleted:etat.leconsCompleted}));}catch(e){}}
function charger(){try{const d=localStorage.getItem('physique_progression');if(d){const p=JSON.parse(d);if(p.eleve){etat.eleve=p.eleve;document.getElementById('nom').value=p.eleve.nom||'';document.getElementById('niveau').value=p.eleve.niveau||'1ere';document.getElementById('serie').value=p.eleve.serie||'D';}if(p.leconsCompleted)etat.leconsCompleted=p.leconsCompleted;return true;}}catch(e){}return false;}
function reinitialiser(){if(confirm('Réinitialiser ?')){localStorage.removeItem('physique_progression');etat.leconsCompleted={};etat.eleve={nom:"",niveau:"1ere",serie:"D"};alert('✅ Réinitialisé.');showPage('page-accueil');}}
function stats(){const c=Object.keys(etat.leconsCompleted).filter(k=>etat.leconsCompleted[k]);return{c:c.length,t:Object.keys(etat.leconsCompleted).length};}
function showPage(id){document.querySelectorAll('[id^="page-"]').forEach(p=>p.classList.add('hidden'));const p=document.getElementById(id);if(p)p.classList.remove('hidden');}
function enregistrer(){const n=document.getElementById('nom').value.trim();if(!n){alert("Entrez votre nom.");return;}etat.eleve={nom:n,niveau:document.getElementById('niveau').value,serie:document.getElementById('serie').value};document.getElementById('eleve-nom').textContent=n;etat.filtreSerie=etat.eleve.serie;document.querySelectorAll('.btn-filtre').forEach(b=>b.classList.toggle('active',b.dataset.filtre===etat.filtreSerie));afficherModules();sauvegarder();showPage('page-modules');}
function demarrer(){if(charger()&&etat.eleve.nom){document.getElementById('eleve-nom').textContent=etat.eleve.nom;etat.filtreSerie=etat.eleve.serie||'D';document.querySelectorAll('.btn-filtre').forEach(b=>b.classList.toggle('active',b.dataset.filtre===etat.filtreSerie));afficherModules();showPage('page-modules');}else{showPage('page-profil');}}
function getModules(){const p=etat.eleve.niveau==="1ere"?"1":"T";return Object.keys(modulesData).filter(k=>k.startsWith(p+etat.filtreSerie)).map(k=>({key:k,...modulesData[k]}));}
function afficherModules(){const mods=getModules();const c=document.getElementById('module-grid');if(mods.length===0){c.innerHTML='<p style="text-align:center;color:#888;padding:20px;">Aucun module.</p>';return;}let h='<div class="module-grid">';mods.forEach(m=>{h+='<button class="btn btn-module" onclick="ouvrirModule(\''+m.key+'\')"><span class="icon">'+m.icone+'</span><span class="titre-module">'+m.titre+'</span></button>';});h+='</div>';c.innerHTML=h;const st=stats();document.getElementById('progression-resume').innerHTML=st.c>0?'📊 Progression : <strong>'+st.c+'</strong> leçons complétées':'📊 Aucune leçon complétée.';}
function changerFiltre(s){etat.filtreSerie=s;document.querySelectorAll('.btn-filtre').forEach(b=>b.classList.toggle('active',b.dataset.filtre===s));afficherModules();}
function ouvrirModule(key){const m=modulesData[key];if(!m)return;etat.moduleActuel=key;document.getElementById('lecon-module-titre').textContent=m.icone+' '+m.titre;let h='';if(m.lecons){m.lecons.forEach((l,i)=>{const num=i+1;const completed=etat.leconsCompleted[key+'_lecon_'+i]||false;h+='<button class="btn-lecon'+(completed?' completed':'')+'" onclick="demarrerLecon(\''+key+'\','+i+')"><span class="lecon-num">'+num+'</span><span class="lecon-titre">'+l.titre+'</span></button>';});}document.getElementById('lecon-grid').innerHTML=h;const total=m.lecons?m.lecons.length:0;const completed=Object.keys(etat.leconsCompleted).filter(k=>k.startsWith(key)&&etat.leconsCompleted[k]).length;const p=total>0?Math.round(completed/total*100):0;const bar=document.getElementById('progress-bar');bar.style.width=p+'%';bar.textContent=p+'%';showPage('page-lecons');}
function retour(){if(etat.moduleActuel)ouvrirModule(etat.moduleActuel);else showPage('page-modules');}
function demarrerLecon(key,idx){const m=modulesData[key];if(!m)return;const l=m.lecons[idx];if(!l)return;etat.moduleActuel=key;etat.leconActuelle=idx;etat.questionActuelle=0;etat.total=l.questions.length;etat.reponses=new Array(etat.total).fill(null);etat.score=0;document.getElementById('quiz-titre').textContent='📖 '+l.titre;document.getElementById('quiz-module').textContent=m.icone+' '+m.titre;showPage('page-quiz');afficherQuestion();}
function afficherQuestion(){if(etat.questionActuelle>=etat.total){terminerLecon();return;}const m=modulesData[etat.moduleActuel];const l=m.lecons[etat.leconActuelle];const q=l.questions[etat.questionActuelle];const idx=etat.questionActuelle;document.getElementById('quiz-progress').textContent=(idx+1)+' / '+etat.total;let h='<div class="question-text">'+q.q+'</div><div class="options-list">';q.o.forEach((opt,i)=>{const lettre=String.fromCharCode(65+i);const checked=etat.reponses[idx]===i?'checked':'';h+='<div class="option-item'+(checked?' selected':'')+'" onclick="selectionnerOption('+idx+','+i+')"><input type="radio" name="q_'+idx+'" value="'+i+'" '+checked+'><label><span>'+lettre+')</span> '+opt+'</label></div>';});h+='</div>';document.getElementById('question-container').innerHTML=h;document.getElementById('correction-container').classList.add('hidden');document.getElementById('correction-container').innerHTML='';const actions=document.getElementById('question-actions');if(etat.reponses[idx]!==null){afficherCorrection(idx);actions.innerHTML='<button class="btn btn-primary" onclick="questionSuivante()">➡️ Suivant</button>';}else{actions.innerHTML='<button class="btn btn-success" onclick="validerReponse()">✅ Valider</button>';}}
function selectionnerOption(idx,opt){if(etat.reponses[idx]!==null)return;const container=document.getElementById('question-container');const items=container.querySelectorAll('.option-item');items.forEach((item,i)=>{const radio=item.querySelector('input[type="radio"]');if(i===opt){item.classList.add('selected');radio.checked=true;}else{item.classList.remove('selected');radio.checked=false;}});container.dataset.selected=opt;}
function validerReponse(){const idx=etat.questionActuelle;const container=document.getElementById('question-container');const selected=container.dataset.selected;if(selected===undefined||selected===''){alert("Choisissez une réponse.");return;}const opt=parseInt(selected);const m=modulesData[etat.moduleActuel];const l=m.lecons[etat.leconActuelle];const q=l.questions[idx];const correct=opt===parseInt(q.r);etat.reponses[idx]=opt;if(correct)etat.score++;document.querySelectorAll('.option-item input[type="radio"]').forEach(r=>r.disabled=true);afficherCorrection(idx);document.getElementById('question-actions').innerHTML='<button class="btn btn-primary" onclick="questionSuivante()">➡️ Suivant</button>';}
function afficherCorrection(idx){const m=modulesData[etat.moduleActuel];const l=m.lecons[etat.leconActuelle];const q=l.questions[idx];const correct=etat.reponses[idx]===parseInt(q.r);const bonne=q.o[parseInt(q.r)];const lettre=String.fromCharCode(65+parseInt(q.r));const container=document.getElementById('correction-container');container.classList.remove('hidden');container.className='correction-box '+(correct?'correct':'incorrect');container.innerHTML='<div class="status">'+(correct?'✅ Bonne réponse !':'❌ Réponse incorrecte')+'</div><div class="explication"><strong>🔍 Explication :</strong><br>'+q.e+(correct?'':'<br><br><strong>✅ Réponse attendue :</strong> '+lettre+') '+bonne)+'</div>';}
function questionSuivante(){etat.questionActuelle++;if(etat.questionActuelle>=etat.total)terminerLecon();else afficherQuestion();}
function terminerLecon(){if(etat.leconActuelle>=0){const key=etat.moduleActuel+'_lecon_'+etat.leconActuelle;etat.leconsCompleted[key]=true;sauvegarder();}showPage('page-resultats');document.getElementById('score-display').innerHTML=etat.score+' <small>/'+etat.total+'</small>';document.getElementById('result-nom').textContent=etat.eleve.nom;document.getElementById('result-juste').textContent=etat.score;document.getElementById('result-faux').textContent=etat.total-etat.score;const m=modulesData[etat.moduleActuel];const l=m.lecons[etat.leconActuelle];document.getElementById('result-titre').textContent='📖 '+l.titre;}
function envoyer(){const eleve=etat.eleve;const m=modulesData[etat.moduleActuel];const l=m.lecons[etat.leconActuelle];let msg='📊 *Résultats - Physique*%0A%0A👨‍🏫 *Prof :* Mr Ndjana a Bidias%0A👤 *Élève :* '+eleve.nom+'%0A📚 *Niveau :* '+eleve.niveau+' '+eleve.serie+'%0A📖 *Module :* '+m.icone+' '+m.titre+'%0A📝 *Leçon :* '+l.titre+'%0A%0A🎯 *Score :* '+etat.score+' / '+etat.total+'%0A✅ Bonnes : '+etat.score+'%0A❌ Mauvaises : '+(etat.total-etat.score);l.questions.forEach((q,i)=>{const rep=etat.reponses[i];const correct=rep===parseInt(q.r);const repText=rep!==null?q.o[rep]:'Non répondue';const bonne=q.o[parseInt(q.r)];msg+='%0A'+(i+1)+'. '+q.q.substring(0,40)+'...%0A   Réponse : '+repText+'%0A   Correcte : '+(correct?'✅':'❌ (Attendue: '+bonne+')');});window.open('https://wa.me/'+NUMERO_WHATSAPP+'?text='+msg,'_blank');}
charger();showPage('page-accueil');
</script>
