        .filtres-container .btn-filtre.active{background:#1a2a6c;color:white}
        .progression-info{text-align:center;font-size:0.8rem;color:#555;padding:8px;background:#f8f9fa;border-radius:8px;border:1px solid #e9ecef;margin-bottom:10px}
        .progress-bar-container{background:#e9ecef;border-radius:20px;height:16px;margin:8px 0;overflow:hidden}
        .progress-bar{background:linear-gradient(90deg,#1a2a6c,#fdbb2d);height:100%;border-radius:20px;transition:width 0.5s;display:flex;align-items:center;justify-content:center;color:white;font-size:0.6rem;font-weight:600}
        .result-detail{text-align:center;font-size:0.9rem}
        @media(max-width:500px){.module-grid{grid-template-columns:1fr}.container{padding:20px}}
