</head>
<body>
<div class="container" id="app">
    <div id="page-accueil">
        <div class="enseignant-info">
            <h1>👨‍🏫 Mr Ndjana a Bidias</h1>
            <h2>PHYSIQUE</h2>
            <div class="numero">📱 WhatsApp : 694 723 256</div>
